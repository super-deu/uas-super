# ============================================================
#  Template konfigurasi Feane. Salin jadi .env lalu isi nilainya.
#  AMAN untuk di-commit (tidak berisi nilai rahasia asli).
# ============================================================

# ---------- Database (docker-compose, pakai root) ----------
DB_HOST=db
DB_PORT=3306
DB_NAME=feane
DB_USER=root
DB_PASS=ganti_password_root
MYSQL_ROOT_PASSWORD=ganti_password_root   # samakan dengan DB_PASS

# ---------- Penamaan image Docker ----------
DOCKERHUB_USERNAME=superdeuuu
DOCKER_REPO_DINAMIS=web-dinamis
DOCKER_REPO_STATIS=web-statis

# ============================================================
#  CI/CD secrets -> SET DI GITHUB REPOSITORY SECRETS (BUKAN di file ini)
#    DOCKERHUB_USERNAME   contoh: superdeuuu
#    DOCKERHUB_TOKEN      Docker Personal Access Token (dckr_pat_...)
#    AWS_HOST             IP publik EC2
#    AWS_USERNAME         ubuntu
#    AWS_SSH_KEY          isi private key .pem
# ============================================================
